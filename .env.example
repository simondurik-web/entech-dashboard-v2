# Google Sheets server-side auth
# Set exactly one of the credential sources below.

# Preferred for hosted runtimes
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Raw JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=

# Absolute or repo-relative path to a JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Optional override. Defaults to the production spreadsheet ID in code.
GOOGLE_SHEET_ID=1bK0Ne-vX3i5wGoqyAklnyFDUNdE-WaN4Xs5XjggBSXw

# Bearer token for the public read-only /api/price-lookup endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PRICE_LOOKUP_API_KEY=
