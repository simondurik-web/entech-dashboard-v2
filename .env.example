# Google Sheets server-side auth
# Set exactly one of the credential sources below.

# Preferred for hosted runtimes
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Raw JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=

# Absolute or repo-relative path to a JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Optional override. Defaults to the production spreadsheet ID in code.
GOOGLE_SHEET_ID=1bK0Ne-vX3i5wGoqyAklnyFDUNdE-WaN4Xs5XjggBSXw

# Bearer token for the public read-only /api/price-lookup endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PRICE_LOOKUP_API_KEY=

# Codex read API — bearer token for /api/codex-query + /api/codex-schema.
# Separate from PRICE_LOOKUP_API_KEY so the two integrations can be rotated
# independently. Generate the same way (32 random bytes, base64url).
CODEX_READER_API_KEY=

# Codex read API — Supabase pooler URL for the codex-api endpoints.
# Vercel serverless can't reach db.<ref>.supabase.co:5432 directly, so this
# goes through the Supabase transaction-mode pooler (port 6543) as the
# `postgres` role; the endpoint then `SET LOCAL ROLE codex_reader` per
# transaction to drop privileges. The role has SELECT on most of `public`
# (auth/PII/audit tables walled off) and no write privileges.
# Format: postgres://postgres.<ref>:<password>@aws-<N>-<region>.pooler.supabase.com:6543/postgres
CODEX_READER_DB_URL=

# Phil Assistant (GPT-5.5) — async job queue
# As of 2026-05-19, the chat path no longer uses these. Vercel POST enqueues
# a row in `phil_jobs` (Supabase) + polls for completion; the Mac mini bridge
# claims jobs via a worker thread. PHIL_AI_WEBHOOK_URL / _SECRET are only
# needed if you ever revert to the synchronous bridge-fetch path or expose
# the bridge's direct /ask endpoint externally. Safe to leave unset on
# Vercel — POST /api/chat/phil ignores them now.
# PHIL_AI_WEBHOOK_URL=
# PHIL_AI_WEBHOOK_SECRET=
